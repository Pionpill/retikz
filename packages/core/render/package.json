{
  "name": "@retikz/render",
  "version": "0.3.0-alpha.6",
  "description": "retikz renderers: Scene → SVG (descriptor / string) and Canvas 2D. Subpath exports per backend (./svg, ./canvas).",
  "type": "module",
  "author": "Pionpill",
  "homepage": "https://pionpill.github.io/retikz/",
  "keywords": [
    "tikz",
    "diagram",
    "svg",
    "canvas",
    "renderer",
    "visualization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pionpill/retikz.git",
    "directory": "packages/core/render"
  },
  "bugs": {
    "url": "https://github.com/Pionpill/retikz/issues"
  },
  "sideEffects": false,
  "exports": {
    "./svg": {
      "types": "./src/svg/index.ts",
      "default": "./src/svg/index.ts"
    },
    "./canvas": {
      "types": "./src/canvas/index.ts",
      "default": "./src/canvas/index.ts"
    },
    "./hydration": {
      "types": "./src/hydration/index.ts",
      "default": "./src/hydration/index.ts"
    },
    "./animation": {
      "types": "./src/animation/index.ts",
      "default": "./src/animation/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      "./svg": {
        "types": "./dist/lib/svg/index.d.ts",
        "import": "./dist/es/svg/index.js",
        "require": "./dist/lib/svg/index.cjs",
        "default": "./dist/es/svg/index.js"
      },
      "./canvas": {
        "types": "./dist/lib/canvas/index.d.ts",
        "import": "./dist/es/canvas/index.js",
        "require": "./dist/lib/canvas/index.cjs",
        "default": "./dist/es/canvas/index.js"
      },
      "./hydration": {
        "types": "./dist/lib/hydration/index.d.ts",
        "import": "./dist/es/hydration/index.js",
        "require": "./dist/lib/hydration/index.cjs",
        "default": "./dist/es/hydration/index.js"
      },
      "./animation": {
        "types": "./dist/lib/animation/index.d.ts",
        "import": "./dist/es/animation/index.js",
        "require": "./dist/lib/animation/index.cjs",
        "default": "./dist/es/animation/index.js"
      }
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@retikz/core": "workspace:*",
    "csstype": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
