{
  "name": "@retikz/core",
  "version": "0.0.1-rc.3",
  "description": "atomic drawing library implemented using react and d3, inspired by tikz",
  "type": "module",
  "homepage": "https://pionpill.github.io/retikz/",
  "keywords": [
    "react",
    "tikz",
    "chart"
  ],
  "license": "MIT",
  "repository": "https://github.com/Pionpill/retikz",
  "sideEffects": false,
  "main": "dist/lib/index.cjs",
  "module": "dist/es/index.js",
  "types": "dist/es/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "d3-color": "catalog:",
    "d3-shape": "catalog:"
  },
  "devDependencies": {
    "@types/d3-color": "catalog:",
    "@types/d3-shape": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
