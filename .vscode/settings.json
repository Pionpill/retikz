{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "explicit",
    "source.fixAll.sortJSON": "explicit"
  },
  "cSpell.words": [
    "clsx",
    "deepseek",
    "frontmatter",
    "languagedetector",
    "lucide",
    "rehype",
    "rollup",
    "vitejs",
    "vitest"
  ]
}
