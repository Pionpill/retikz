# apps/eval 本地评测密钥模板。复制为 .env 后填入真实 key：
#   cp .env.example .env        （PowerShell: Copy-Item .env.example .env）
# .env 已被仓库根 .gitignore 忽略，不会入库。
# `pnpm --filter @retikz/eval eval` 会自动加载 .env（缺失也不报错）。

# anthropic：填 key 即可用（权威默认模型 claude-opus-4-8）
ANTHROPIC_API_KEY=

# openai / deepseek：须同时填 key 与显式模型 id 才启用
# OPENAI_API_KEY=
# EVAL_OPENAI_MODEL=gpt-4o
# DEEPSEEK_API_KEY=
# EVAL_DEEPSEEK_MODEL=deepseek-chat

# 可选
# EVAL_K=3
# EVAL_ANTHROPIC_MODEL=claude-opus-4-8
